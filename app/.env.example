# Dossiers locaux des modèles
MODEL_DIR_WO=./afriklang_asr_wo1
MODEL_DIR_TWI=./afriklang_asr_tw1
MODEL_DIR_TTS_TWI=./afriklang_twi_ttsv1

# Bucket S3 contenant les modèles (laisser vide si déjà en local)
S3_BUCKET=sagemaker-us-east-1-478335820298

# Traduction (optionnel) — sans clé, le paramètre ?target_lang est simplement ignoré
# GITHUB_MODELS_TOKEN a priorité sur RODIUMAI_API_KEY si les deux sont définis.
# PAT GitHub avec permission "Models: Read-only" : https://github.com/settings/personal-access-tokens/new
# Gratuit, quota limité (15 req/min, 150 req/jour pour gpt-4o-mini).
GITHUB_MODELS_TOKEN=
RODIUMAI_API_KEY=
TRANSLATION_MODEL=openai/gpt-4o-mini
