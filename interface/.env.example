# Copy to .env.local and fill in real values. Do NOT commit .env.local.
#
# Base URL of the Afriklang ASR (Wolof) service. Server-only: this is read by the
# /api/asr/transcribe route handler and must never be prefixed with NEXT_PUBLIC_.
ASR_API_URL=https://asr.afriklang.com

# --- Reserved for the deferred S3 audio-storage work (not used yet) ---
# AWS_REGION=
# ASR_AUDIO_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
