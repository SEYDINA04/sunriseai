# Copy to .env.local and fill in real values. Do NOT commit .env.local.
#
# Base URL of the Afriklang ASR service (v2). The route handler appends the
# language-specific path automatically:
#   lang=WO  →  {ASR_API_URL}/transcribe/wo
#   lang=TW  →  {ASR_API_URL}/transcribe/twi
# Server-only: must NEVER be prefixed with NEXT_PUBLIC_.
ASR_API_URL=https://asr.afriklang.com

# Base WebSocket URL for live ASR (client-visible, safe to expose).
# Chantier 3: WS /transcribe/live/{lang}  e.g. wss://asr.afriklang.com/transcribe/live/wo
NEXT_PUBLIC_ASR_WS_URL=wss://asr.afriklang.com

# --- Reserved for the deferred S3 audio-storage work (not used yet) ---
# AWS_REGION=
# ASR_AUDIO_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
