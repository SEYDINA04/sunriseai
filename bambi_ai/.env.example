# Copy this to .env and fill in the values

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# PostgreSQL — matches the docker-compose defaults
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bambi_ai

# Redis — matches the docker-compose defaults
REDIS_URL=redis://localhost:6379/0

# Public HTTPS base URL for webhook registration (no trailing slash)
# Use ngrok for local dev: ngrok http 8000 → paste the https URL here
# Leave empty to skip auto-registration (you can set it manually via Telegram API)
WEBHOOK_BASE_URL=

# Speech integration
# true  = return realistic mock transcripts (no ASR endpoint needed)
# false = call the real Teeki AI ASR endpoints
MOCK_MODE=true
TEEKI_BASE_URL=https://asr.afriklang.com

# Local directory where voice files are stored
AUDIO_DIR=audio_store

# OpenAI TTS — leave empty to disable voice confirmations (text-only replies)
# When set, the bot sends back a spoken confirmation after each voicemail is queued
OPENAI_API_KEY=
